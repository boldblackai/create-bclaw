# AWS credentials for the claw's deployer IAM user.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored —
# never commit real credentials. `mise` loads `.env` via the `[env] _.file`
# entry in `mise.toml` so every shell that runs `aws` has them exported.
#
# Create the deployer IAM user + access key per README → Setup → steps 1-2,
# then paste the access key here.

export AWS_ACCESS_KEY_ID=AKIAEXAMPLE
export AWS_SECRET_ACCESS_KEY=replace-with-the-secret-access-key
export AWS_REGION=us-east-1

# Alternative to the two keys above: use a named AWS profile instead of static
# keys (e.g. an SSO role configured via `aws configure`). Uncomment and set,
# and delete the two keys above.
# AWS_PROFILE=bclaw-deployer
