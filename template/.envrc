# Loads AWS credentials and region from .env (gitignored) into every shell.
# .env holds AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (or AWS_PROFILE) + AWS_REGION.
# The setup-bclaw / teardown-bclaw skills assume
# these are exported. Never commit .env.
if [ -f .env ]; then
  # shellcheck disable=SC1091
  . ./.env
fi
