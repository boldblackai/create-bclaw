{
  "name": "@boldblackai/create-bclaw",
  "version": "1.0.0",
  "description": "Deploy your own long-running Hermes agent on Slack + AWS",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-bclaw": "dist/cli.js"
  },
  "packageManager": "pnpm@11.9.0",
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "tsc && node --test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/node": "22.20.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "create",
    "scaffold",
    "hermes",
    "harness",
    "ecs",
    "slack",
    "aws"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boldblackai/create-bclaw.git"
  },
  "homepage": "https://github.com/boldblackai/create-bclaw#readme"
}
