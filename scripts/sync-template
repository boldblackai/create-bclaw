#!/usr/bin/env bash
# Refresh the bundled template/ snapshot from references/bclaw-repo.
#
# references/bclaw-repo is the SOURCE OF TRUTH; template/ is the DERIVED
# artifact shipped inside the npm package (listed in package.json#files).
# Run this after editing the source, then commit both. The golden CI test
# (invariant 1) verifies template/ stays in sync.
#
# Excludes .git (nested VCS) and .env (real secrets). Keeps .envrc and
# .env.example.
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
src="$root/references/bclaw-repo"
dest="$root/template"

if [ ! -d "$src" ]; then
  echo "sync-template: source not found: $src" >&2
  exit 1
fi

# Start from a clean snapshot so deletions in the source propagate.
rm -rf "$dest"
mkdir -p "$dest"

if command -v rsync >/dev/null 2>&1; then
  rsync -a --exclude='.git/' --exclude='.env' "$src/" "$dest/"
else
  # Fallback: tar pipe (also preserves dotfiles, honors the excludes)
  ( cd "$src" && tar -cf - --exclude='./.git' --exclude='./.env' . ) \
    | ( cd "$dest" && tar -xf - )
fi

echo "sync-template: refreshed $dest from $src"
